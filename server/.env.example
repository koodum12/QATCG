# OpenAI API 키 (필수). 이 파일을 .env로 복사한 뒤 실제 키를 넣으세요.
OPENAI_API_KEY=sk-...

# 사용할 모델 (기본 gpt-5.5)
OPENAI_MODEL=gpt-5.5

# reasoning 강도: low | medium | high | xhigh (기본 medium)
REASONING_EFFORT=medium

# 난이도/테스트 방식 분류용 경량 모델 (기본 gpt-4o-mini)
CLASSIFY_MODEL=gpt-4o-mini

# SQLite DB 파일 경로 (기본: server 폴더의 qa.db)
DB_PATH=qa.db
